# Session
SESSION_SECRET=your_session_secret_here

# Database (Supabase) - using DATABASE_URL format
# Format: postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your_password_here@db.your-project.supabase.co:5432/postgres?sslmode=require

# Alternative: Individual database variables (if not using DATABASE_URL)
# CANER_DB_USER=postgres
# CANER_DB_PASSWORD=your_password_here
# CANER_DB_HOST=db.your-project.supabase.co:5432
# CANER_DB_NAME=postgres

# API Keys
MISTRAL_API_KEY=your_mistral_api_key_here
