# Docker-compatible environment variables
# IMPORTANT: All values must be single-line (no multi-line strings).
# Docker Compose's .env parser is stricter than Python's python-dotenv.
# Use \n for newlines within values instead of actual line breaks.

SESSION_SECRET=your_session_secret_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional public origin for canonical URLs, sitemap, and llms.txt.
# Leave empty for local runs so the request origin is used.
# SITE_URL=https://caner.example.com
AI_MODEL=mistralai/mistral-small
AI_MAX_TOKENS=500
AI_MODEL_MAX=mistralai/mistral-small
AI_MAX_TOKENS_MAX=500
STARTUP_MPS_ENABLED=true
STARTUP_MPS_BACKGROUND=true
MPS_REQUEST_DELAY_SECONDS=0.5
MEAL_TRANSLATION_ENABLED=true
STARTUP_TRANSLATIONS_ENABLED=true
STARTUP_TRANSLATIONS_BACKGROUND=true
MEAL_TRANSLATION_BATCH_SIZE=20
MEAL_TRANSLATION_WORKERS=2
MEAL_TRANSLATION_REQUEST_DELAY_SECONDS=0.5
MEAL_IMAGE_CACHE_DIR=/app/data/meal_images
MEAL_IMAGE_THUMBNAIL_SIZE=240
MEAL_IMAGE_THUMBNAIL_QUALITY=72
MEAL_IMAGE_NEGATIVE_LOOKUP_TTL_SECONDS=21600

POSTGRES_DB=caner
POSTGRES_USER=caner
POSTGRES_PASSWORD=change_this_local_password

# Optional: image used by docker-compose.remote.yml on remote machines
# CANER_IMAGE=ghcr.io/match-misc/caner:latest

# PROMPT_MPS=Your single-line prompt here with \n for newlines
# PROMPT_MARVIN=Your German Marvin prompt here with {meal_list} and \n for newlines
# PROMPT_MARVIN_EN=Your English Marvin prompt here with {meal_list} and \n for newlines
# PROMPT_GORDON=Your German Gordon Ramsay prompt here with {meal_list} and \n for newlines
# PROMPT_GORDON_EN=Your English Gordon Ramsay prompt here with {meal_list} and \n for newlines
# PROMPT_RICK=Your German Rick Sanchez prompt here with {meal_list} and \n for newlines
# PROMPT_RICK_EN=Your English Rick Sanchez prompt here with {meal_list} and \n for newlines
# PROMPT_TRUMP=Your English Donald Trump prompt here with {mensa}, {meal_list}, and \n for newlines
# PROMPT_RECOMMENDATION=Fallback German prompt for custom recommenders with {recommender}, {mensa}, {meal_list}, and \n for newlines
# PROMPT_RECOMMENDATION_EN=Fallback English prompt for custom recommenders with {recommender}, {mensa}, {meal_list}, and \n for newlines
# PROMPT_MEAL_TRANSLATION=Your single-line prompt here with {meal_list} and \n for newlines
# PROMPT_COMMENT_TRANSLATION=Your single-line prompt here with {source_language}, {comment_text}, and \n for newlines
