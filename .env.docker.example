# Docker Environment Variables for Das Caner
# Copy this file to .env and fill in the values

# Session secret (generate a random string)
SESSION_SECRET=your_session_secret_here

# Database URL (Supabase PostgreSQL)
# Format: postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:your_password_here@db.your-project.supabase.co:5432/postgres?sslmode=require

# Mistral API Key for AI recommendations
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional: Override port (default is 30823)
# PORT=30823
