# Docker-compatible environment variables
# IMPORTANT: All values must be single-line (no multi-line strings).
# Docker Compose's .env parser is stricter than Python's python-dotenv.
# Use \n for newlines within values instead of actual line breaks.

SESSION_SECRET=your_session_secret_here
DATABASE_URL=postgresql://postgres:your_password_here@db.your-project.supabase.co:5432/postgres?sslmode=require
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_MODEL=mistralai/mistral-small
AI_MAX_TOKENS=500

# Optional: Set to true to force-disable the Sambal Alarm (visual overlay and AI instruction)
# DISABLE_SAMBAL_ALARM=false

# PROMPT_MPS=Your single-line prompt here with \n for newlines
# PROMPT_TRUMP=Your single-line prompt here with \n for newlines
# PROMPT_BOB=Your single-line prompt here with \n for newlines
# PROMPT_MARVIN=Your single-line prompt here with \n for newlines
# PROMPT_DARK_CANER=Your single-line prompt here with \n for newlines
